    <string name="general_information">Añade el icono de Batería a tu panel de Ajustes Rápidos para ver el porcentaje de batería de un vistazo, o añade una notificación persistente para obtener mucha más información y notificaciones adicionales.\n\nEsta app no envía ningún tipo de información fuera de tu dispositivo (no incluye el permiso de acceso a Internet) ni solicita ningún permiso especial, así que puedes usarla tranquilamente.</string>

    <string name="battery_charged_section_title">Notificación de batería cargada</string>
    <string name="battery_charged_section_body">Puedes configurar el nivel de carga necesario para considerar el dispositivo cargado, el retardo para la primera notificación y si quieres notificaciones periódicas.\n\nTenga en cuenta que, si selecciona un valor inferior al 100%, el dispositivo continuará cargándose hasta que lo desconecte.</string>
    <string name="battery_charged_threshold">Umbral de notificación</string>
    <string name="battery_charged_interval">Retardo de notificación de carga</string>
    <string name="battery_charged_repeat_interval">Intervalo de repetición</string>

    <string name="power_connected_or_disconnected_section_title">Notificationes de conexión o desconexión</string>
    <string name="power_connected_or_disconnected_section_body">Recibirás una notificación cuando el dispositivo se conecte o desconecte de una fuente de carga.</string>
    <string name="block_power_disconnect_notification_when_battery_is_charged">Bloquea la notificación de desconexión si la batería está cargada</string>

    <string name="battery_temperature_section_title">Notificación de temperatura alta de la batería</string>
    <string name="battery_temperature_section_body">Recibirás una notificación cuando la temperatura de la batería supere el umbral configurado.</string>
    <string name="battery_temperature_threshold">Umbral de temperatura</string>

